# Percorso al file delle credenziali OAuth2 scaricato da Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json

# Percorso dove salvare/leggere il token (generato da: python -m dinner_planner.auth)
GOOGLE_TOKEN_PATH=token.json

# Per GitHub Actions: contenuto di token.json codificato in base64
# GOOGLE_TOKEN_JSON=<base64 di token.json>
# GOOGLE_CREDENTIALS_JSON=<base64 di credentials.json>

# Email destinatario
RECIPIENT_EMAIL=a.tummillo@gmail.com
